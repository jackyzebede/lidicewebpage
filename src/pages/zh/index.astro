---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import Somos from '../../components/Somos.astro';
import Tramites from '../../components/Tramites.astro';
import Services from '../../components/Services.astro';
import Consolidado from '../../components/Consolidado.astro';
import Fletes from '../../components/Fletes.astro';
import Contactos from '../../components/Contactos.astro';
import Footer from '../../components/Footer.astro';

const lang = 'zh' as const;
---

<Layout
  lang={lang}
  title="Lidice Logistic · 巴拿马物流伙伴"
  description="40多年的物流、报关和迈阿密-巴拿马拼柜经验。100% 巴拿马企业。"
>
  <Header lang={lang} />
  <main>
    <Hero lang={lang} />
    <Somos lang={lang} />
    <Tramites lang={lang} />
    <Services lang={lang} />
    <Consolidado lang={lang} />
    <Fletes lang={lang} />
    <Contactos lang={lang} />
  </main>
  <Footer lang={lang} />
</Layout>
