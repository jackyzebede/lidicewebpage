---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const schedule = [
  { label: t('consol.cut'), value: t('consol.cut.v'), icon: 'calendar' },
  { label: t('consol.load'), value: t('consol.load.v'), icon: 'package' },
  { label: t('consol.depart'), value: t('consol.depart.v'), icon: 'ship' },
  { label: t('consol.freq'), value: t('consol.freq.v'), icon: 'refresh' },
  { label: t('consol.transit'), value: t('consol.transit.v'), icon: 'clock' },
];
---

<section id="consolidado" class="py-24 md:py-32 bg-lidice-blue relative overflow-hidden">
  <img
    src="/images/consolidadoBg-desktop.webp"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-[0.08] pointer-events-none"
    loading="lazy"
  />

  <div class="section relative text-white">
    <div class="grid md:grid-cols-12 gap-8 mb-14">
      <div class="md:col-span-5">
        <p class="kicker mb-6 reveal">Miami — Panamá</p>
        <h2 class="h2 mb-6 reveal reveal-delay-1">{t('consol.title')}</h2>
      </div>
      <div class="md:col-span-7 md:pt-8">
        <p class="lead !text-white/70 max-w-xl reveal reveal-delay-2">{t('consol.sub')}</p>
      </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-5 border-t border-l border-white/10 reveal reveal-delay-3">
      {schedule.map((item) => (
        <div class="p-6 md:p-8 border-b border-r border-white/10 hover:bg-white/[0.04] transition-colors">
          <div class="text-lidice-orange mb-4">
            <Icon name={item.icon} class="w-6 h-6" />
          </div>
          <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-white/50 mb-3">
            {item.label}
          </p>
          <p class="font-display text-xl md:text-2xl leading-tight text-white">
            {item.value}
          </p>
        </div>
      ))}
    </div>

    <div class="mt-14 reveal reveal-delay-4">
      <a href="#contacto" class="btn-primary">{t('consol.cta')}</a>
    </div>
  </div>
</section>
