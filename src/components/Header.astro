---
import type { Lang } from '../i18n/ui';
import { useTranslations, localizedPath } from '../i18n/utils';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const t = useTranslations(lang);
const base = localizedPath(lang, '/');
---

<header class="fixed top-0 left-0 right-0 z-50 bg-white/95 backdrop-blur border-b border-lidice-blue/5">
  <div class="section flex items-center justify-between py-5">
    <a href={base} class="flex items-center" aria-label="Lidice Logistic">
      <img
        src="/images/brand/logo-positivo.png"
        alt="Lidice Logistic"
        class="h-9 md:h-10 w-auto"
        width="180"
        height="40"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-10 text-[13px] font-semibold tracking-wide">
      <a href={`${base}#somos`} class="hover:text-lidice-orange transition-colors uppercase">{t('nav.somos')}</a>
      <a href={`${base}#services`} class="hover:text-lidice-orange transition-colors uppercase">{t('nav.services')}</a>
      <a href={`${base}#consolidado`} class="hover:text-lidice-orange transition-colors uppercase">{t('nav.consolidado')}</a>
      <a href={`${base}#fletes`} class="hover:text-lidice-orange transition-colors uppercase">{t('nav.fletes')}</a>
      <a href={`${base}#contacto`} class="hover:text-lidice-orange transition-colors uppercase">{t('nav.contacto')}</a>
    </nav>

    <div class="flex items-center gap-4 md:gap-6">
      <div class="flex items-center gap-3 text-[11px] font-semibold tracking-wider">
        <a
          href="/"
          class:list={['transition-colors', lang === 'es' ? 'text-lidice-blue' : 'text-lidice-blue/30 hover:text-lidice-blue']}
          aria-label="Español"
        >ES</a>
        <span class="text-lidice-blue/15">/</span>
        <a
          href="/en/"
          class:list={['transition-colors', lang === 'en' ? 'text-lidice-blue' : 'text-lidice-blue/30 hover:text-lidice-blue']}
          aria-label="English"
        >EN</a>
        <span class="text-lidice-blue/15">/</span>
        <a
          href="/zh/"
          class:list={['transition-colors', lang === 'zh' ? 'text-lidice-blue' : 'text-lidice-blue/30 hover:text-lidice-blue']}
          aria-label="中文"
        >中</a>
      </div>

      <a href={`${base}#contacto`} class="hidden md:inline-flex bg-lidice-blue text-white px-5 py-2.5 text-[12px] font-semibold tracking-wide uppercase hover:bg-lidice-orange transition-colors">
        {t('nav.cta')}
      </a>
    </div>
  </div>
</header>
