---
import type { Lang } from '../i18n/ui';

interface Props { lang: Lang; }
const { lang } = Astro.props;

const phone = '50766145557';
const messages: Record<Lang, string> = {
  es: 'Hola, me gustaría solicitar información sobre sus servicios.',
  en: 'Hello, I would like to request information about your services.',
  zh: '您好,我想咨询一下贵公司的服务。',
};
const labels: Record<Lang, string> = {
  es: 'Escríbenos por WhatsApp',
  en: 'Chat with us on WhatsApp',
  zh: '通过 WhatsApp 联系我们',
};

const href = `https://wa.me/${phone}?text=${encodeURIComponent(messages[lang])}`;
const label = labels[lang];
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  aria-label={label}
  class="wa-fab fixed bottom-5 right-5 md:bottom-7 md:right-7 z-[60] flex items-center justify-center w-14 h-14 md:w-16 md:h-16 rounded-full bg-[#25D366] text-white shadow-lg shadow-black/20 transition-transform hover:scale-110 hover:bg-[#1ebe5a]"
>
  <svg viewBox="0 0 32 32" class="w-7 h-7 md:w-8 md:h-8" fill="currentColor" aria-hidden="true">
    <path d="M19.11 17.205c-.372 0-1.088 1.39-1.518 1.39a.63.63 0 0 1-.315-.1c-.802-.402-1.504-.817-2.163-1.447-.545-.516-1.146-1.29-1.46-1.963a.426.426 0 0 1-.073-.215c0-.33.99-.945.99-1.49 0-.143-.73-2.09-.832-2.335-.143-.372-.214-.487-.6-.487-.187 0-.36-.043-.53-.043-.302 0-.53.115-.746.315-.688.645-1.032 1.318-1.06 2.264v.114c-.015.99.472 1.977 1.017 2.78 1.23 1.82 2.506 3.41 4.554 4.34.616.287 2.035.888 2.722.888.817 0 2.15-.515 2.478-1.318.13-.314.13-.6.158-.93-.185-.302-2.12-1.234-2.62-1.504zm-2.92 7.255c-5.21 0-9.46-4.242-9.46-9.452 0-2.076.643-3.952 1.82-5.478L6.35 13.668l1.775-.2A9.449 9.449 0 0 1 16.188 7c5.21 0 9.45 4.24 9.45 9.45 0 5.212-4.24 9.453-9.45 9.453m7.47-16.84A10.79 10.79 0 0 0 16.187 5.14c-6.148 0-10.87 4.782-10.87 10.868 0 1.974.442 3.762 1.202 5.397L5.38 25.32l3.973-1.025c1.576.862 3.37 1.347 5.23 1.347h.05c5.95 0 10.81-4.48 10.81-10.81 0-3.205-1.39-6.003-3.71-8.212M16.187 25c-.05 0-.1 0-.15-.008-1.76 0-3.482-.47-4.985-1.36l-.358-.213-3.706.968.99-3.61-.232-.37a9.34 9.34 0 0 1-1.428-5.01c0-5.19 4.234-9.424 9.425-9.424 2.505 0 4.865.97 6.646 2.74a9.385 9.385 0 0 1 2.76 6.67C25.148 20.76 20.96 25 16.187 25z"/>
