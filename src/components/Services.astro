---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';
import Icon from './Icon.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);

const groups = [
  { key: 'g1', icon: 'document', services: ['s1', 's2', 's3'] },
  { key: 'g2', icon: 'container', services: ['s1', 's2', 's3'] },
  { key: 'g3', icon: 'receipt', services: ['s1', 's2', 's3'] },
  { key: 'g4', icon: 'building', services: ['s1'] },
  { key: 'g5', icon: 'star', services: ['s1', 's2', 's3'] },
  { key: 'g6', icon: 'cog', services: ['s1', 's2'] },
];
---

<section id="services" class="py-24 md:py-32 bg-lidice-gray">
  <div class="section">
    <div class="grid md:grid-cols-12 gap-8 mb-16 md:mb-20">
      <div class="md:col-span-4">
        <p class="kicker mb-6 reveal">{t('services.kicker')}</p>
      </div>
      <div class="md:col-span-8">
        <h2 class="h2 text-lidice-blue mb-6 reveal reveal-delay-1">{t('services.title')}</h2>
        <p class="lead max-w-2xl reveal reveal-delay-2">{t('services.sub')}</p>
      </div>
    </div>

    <div class="grid md:grid-cols-2 lg:grid-cols-3 border-t border-l border-lidice-blue/10">
      {groups.map((g, idx) => (
        <div class={`p-8 lg:p-10 border-b border-r border-lidice-blue/10 bg-white hover:bg-lidice-blue hover:text-white transition-colors duration-300 group reveal reveal-delay-${Math.min(idx + 1, 6)}`}>
          <div class="flex items-start gap-4 mb-6">
            <div class="text-lidice-orange shrink-0">
              <Icon name={g.icon} class="w-8 h-8" />
            </div>
            <div class="min-w-0">
              <p class="text-[10px] font-semibold tracking-[0.2em] uppercase text-lidice-blue/40 group-hover:text-white/40 mb-2">
                0{idx + 1}
              </p>
              <h3 class="font-display text-xl leading-tight">{t(`services.${g.key}.title` as any)}</h3>
            </div>
          </div>
          <ul class="space-y-5 pt-5 border-t border-lidice-blue/10 group-hover:border-white/10">
            {g.services.map((s) => (
              <li>
                <p class="font-semibold text-sm mb-1">
                  {t(`services.${g.key}.${s}.title` as any)}
                </p>
                <p class="text-[13px] leading-relaxed text-lidice-blue/60 group-hover:text-white/60">
                  {t(`services.${g.key}.${s}.body` as any)}
                </p>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>
