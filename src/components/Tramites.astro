---
import type { Lang } from '../i18n/ui';
import { useTranslations } from '../i18n/utils';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="tramites" class="py-24 md:py-32 bg-white relative overflow-hidden">
  <img
    src="/images/mapa-desktop.webp"
    alt=""
    class="absolute inset-0 w-full h-full object-cover opacity-10 pointer-events-none"
    loading="lazy"
  />

  <div class="section relative">
    <div class="max-w-3xl mx-auto text-center">
      <p class="kicker mb-4">Lidice</p>
      <h2 class="h2 text-lidice-blue mb-10">{t('tramites.title')}</h2>

      <div class="space-y-6 text-left md:text-center">
        <p class="lead">{t('tramites.p1')}</p>
        <p class="lead">{t('tramites.p2')}</p>
        <p class="lead">{t('tramites.p3')}</p>
      </div>

      <a href="#contacto" class="btn-primary mt-10">{t('tramites.cta')}</a>
    </div>
  </div>
</section>
